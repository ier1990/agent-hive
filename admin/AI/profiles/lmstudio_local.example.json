{
  "profile_name": "lmstudio-local",
  "task_name": "local_general_use",
  "description": "Starter profile for a local LM Studio server using an OpenAI-compatible /v1 endpoint.",
  "mode": "shell",
  "provider": "local",
  "base_url": "http://127.0.0.1:1234/v1",
  "model": "openai/gpt-oss-20b",
  "api_key_env": "LLM_API_KEY",
  "interactive": true,
  "output_mode": "plain",
  "write_report": false,
  "memory_enabled": true,
  "step_budget": 6,
  "max_steps": 6,
  "temperature": 0.2,
  "startup_greeting_enabled": true,
  "startup_greeting_prompt": "Say a short greeting and introduce yourself in 2 short sentences.",
  "notes_db": "/web/private/db/memory/human_notes.db",
  "code_root": "/web/html",
  "boot_prompt_path": "/web/html/admin/AI/agent_boot.md",
  "tool_settings_path": "/web/private/agent_tools.json",
  "default_query": "",
  "task_prompt": "",
  "timeout_seconds": 120
}
